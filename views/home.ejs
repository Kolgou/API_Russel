<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Accueil - Système de Gestion de Catways</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <div class="nav-brand">Catway Manager</div>
      <div class="nav-links">
        <a href="/documentation">Documentation API</a>
        <% if (user) { %>
          <a href="/dashboard">Tableau de bord</a>
          <a href="/logout">Déconnexion</a>
        <% } %>
      </div>
    </div>
  </nav>

  <div class="container">
    <div class="home-section">
      <div class="hero">
        <h1>Bienvenue au Système de Gestion de Catways</h1>
        <p>Gérez efficacement les catways (emplacements de port) et les réservations</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <div class="login-form-container">
        <h2>Connexion</h2>
        <form method="POST" action="/login" class="form">
          <div class="form-group">
            <label for="username">Nom d'utilisateur:</label>
            <input type="text" id="username" name="username" required>
          </div>
          <div class="form-group">
            <label for="password">Mot de passe:</label>
            <input type="password" id="password" name="password" required>
          </div>
          <button type="submit" class="btn btn-primary">Se connecter</button>
        </form>
      </div>

      <div class="info-section">
        <h2>À propos</h2>
        <p>Cette application permet de:</p>
        <ul>
          <li>Gérer les utilisateurs (créer, modifier, supprimer)</li>
          <li>Administrer les catways et leurs états</li>
          <li>Créer et gérer les réservations</li>
          <li>Consulter la documentation de l'API</li>
        </ul>
      </div>
    </div>
  </div>

  <footer>
    <p>&copy; 2026 Système de Gestion de Catways. Tous droits réservés.</p>
  </footer>
</body>
</html>
