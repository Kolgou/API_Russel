<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Détails du Catway</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <div class="nav-brand">Catway Manager</div>
      <div class="nav-links">
        <a href="/">Accueil</a>
        <% if (user) { %>
          <a href="/dashboard">Tableau de bord</a>
        <% } %>
        <a href="/catways">Catways</a>
        <a href="/documentation">Documentation</a>
        <% if (user) { %>
          <a href="/logout">Déconnexion</a>
        <% } %>
      </div>
    </div>
  </nav>

  <div class="container">
    <h1>Détails du Catway #<%= catway.catwayNumber %></h1>

    <div class="detail-card">
      <div class="detail-row">
        <label>Numéro:</label>
        <value><%= catway.catwayNumber %></value>
      </div>
      <div class="detail-row">
        <label>Type:</label>
        <value><%= catway.type %></value>
      </div>
      <div class="detail-row">
        <label>État:</label>
        <value><span class="badge"><%= catway.catwayState %></span></value>
      </div>
      <% if (catway.createdAt) { %>
        <div class="detail-row">
          <label>Créé le:</label>
          <value><%= new Date(catway.createdAt).toLocaleString('fr-FR') %></value>
        </div>
      <% } %>
      <% if (catway.updatedAt) { %>
        <div class="detail-row">
          <label>Modifié le:</label>
          <value><%= new Date(catway.updatedAt).toLocaleString('fr-FR') %></value>
        </div>
      <% } %>
    </div>

    <div class="back-link">
      <a href="/catways">Retour à la liste</a>
    </div>
  </div>

  <footer>
    <p>&copy; 2026 Système de Gestion de Catways. Tous droits réservés.</p>
  </footer>
</body>
</html>
